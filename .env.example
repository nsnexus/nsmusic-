# Gemini API configuration for composing lyrics (supports comma-separated keys for auto-failover rotation)
GEMINI_API_KEYS=your_first_gemini_key_here,your_second_gemini_key_here

# Mercado Pago API configuration for processing checkout payments
MERCADO_PAGO_ACCESS_TOKEN=your_mercado_pago_access_token_here

# NextJS Site URL (used for webhooks and payment redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
